# Guacamole RemoteApp Portal — 生产环境专用 .env 模板
# 用法：
# 1. 复制本文件为 deploy/.env
# 2. 把所有 REPLACE_* 占位符换成真实值
# 3. 启动：cd deploy && docker compose up -d --build
#
# 重要：
# - 生产 Linux 服务器不需要 host_port_bridge.py
# - PORTAL_HOST 是“用户访问门户的地址”，不是 Windows RemoteApp 主机地址
# - Windows RemoteApp 主机地址在数据库 remote_app.hostname 里单独维护

# ============================================================
# Compose 实例标识
# - 同机部署多套实例时必须唯一
# - 会影响容器名、volume 名、备份脚本行为
# ============================================================
PORTAL_INSTANCE_ID=nercar-portal-prod

# ============================================================
# MySQL
# - Portal 后端通过 root 连 portal DB
# - guac-web 通过 MYSQL_USER / MYSQL_PASSWORD 连 guacamole_db
# - 两个密码都必须换掉，别拿开发环境密码上生产
# ============================================================
MYSQL_ROOT_PASSWORD=REPLACE_WITH_STRONG_ROOT_PASSWORD
MYSQL_USER=guacamole_user
MYSQL_PASSWORD=REPLACE_WITH_STRONG_GUAC_DB_PASSWORD
MYSQL_DATABASE=guacamole_db

# 可选：如果你需要从宿主机直连 MySQL 做维护，再显式开放一个本机端口
# 不需要就保持注释，别手贱往公网放数据库
# MYSQL_HOST_PORT=33060

# ============================================================
# Guacamole JSON Auth 密钥
# - 必须与 Portal 后端读取到的值一致
# - 这里是 128-bit hex，也就是 32 个十六进制字符
# - 示例占位符不是有效密钥，自己生成
# ============================================================
JSON_SECRET_KEY=REPLACE_WITH_32_HEX_CHARS

# ============================================================
# Portal 对外地址
# PORTAL_HOST:
#   - 用户浏览器真正访问的域名或 IP
#   - 例如 portal.example.com
#   - 不是 remote_app.hostname
#
# PORTAL_BIND_IP:
#   - Linux 服务器直接对外提供服务：0.0.0.0
#   - 如果前面还有正式反向代理，只想监听本机：127.0.0.1
#
# PORTAL_PORT:
#   - 对外发布端口
#   - 直接对外常见值：80 / 443(通常由外层代理处理) / 8880
#   - 如果前面还有反向代理，内部常见值：18880
# ============================================================
PORTAL_HOST=portal.example.com
PORTAL_BIND_IP=0.0.0.0
PORTAL_PORT=8880

# Portal JWT 签名密钥
# - 必须替换为高强度随机字符串
PORTAL_JWT_SECRET=REPLACE_WITH_LONG_RANDOM_JWT_SECRET

# ============================================================
# 数据持久化目录（生产环境强烈建议显式绑定）
# - 必须位于 Linux 本地文件系统
# - 启动前先 mkdir -p 这些目录
# - MySQL 数据目录别放到大小写不敏感或奇怪的网络盘上
# ============================================================
MYSQL_DATA_SOURCE=/srv/nercar-portal/mysql
GUAC_DRIVE_SOURCE=/srv/nercar-portal/drive

# ============================================================
# 时区
# ============================================================
TZ=Asia/Shanghai

# ============================================================
# 生产部署前必须额外确认的非 .env 项
# 1. 数据库 guacamole_portal_db.remote_app.hostname
#    - 改成真实 Windows RemoteApp / RDP 主机地址
# 2. 如果启用脚本任务：
#    - 检查 worker_group / worker_node / enrollment / token
#    - 检查 Worker 主机名、scratch_root、workspace_share
# 3. 如果前面挂正式 HTTPS 反向代理：
#    - 建议改为：
#      PORTAL_BIND_IP=127.0.0.1
#      PORTAL_PORT=18880
#    - 再由外层 Nginx/Caddy/LB 反代到 127.0.0.1:18880
# ============================================================
