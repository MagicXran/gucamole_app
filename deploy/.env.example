# Guacamole RemoteApp Portal — 部署配置模板
# 复制为同目录 .env 后填写真实值；deploy/.env 不应提交到仓库

# MySQL
MYSQL_ROOT_PASSWORD=your_strong_root_password
MYSQL_USER=guacamole_user
MYSQL_PASSWORD=your_strong_db_password
MYSQL_DATABASE=guacamole_db

# Guacamole JSON Auth 密钥（128-bit hex）
# 必须是 32 位十六进制字符串（128-bit AES 密钥）
JSON_SECRET_KEY=00112233445566778899aabbccddeeff

# Portal 配置
PORTAL_HOST=your.portal.host
PORTAL_PORT=8880

# Portal JWT 密钥（可选；不填会退回使用 JSON_SECRET_KEY/GUACAMOLE_JSON_SECRET_KEY）
PORTAL_JWT_SECRET=your_portal_jwt_secret

# 首次部署管理员（首次部署且库中尚无管理员时必须填写，创建后即可移除）
PORTAL_BOOTSTRAP_ADMIN_USERNAME=portaladmin
PORTAL_BOOTSTRAP_ADMIN_PASSWORD=change_this_bootstrap_admin_password
PORTAL_BOOTSTRAP_ADMIN_DISPLAY_NAME=管理员

# guacd 日志级别（可选：info/debug/...）
GUACD_LOG_LEVEL=info

# 数据持久化目录 (仅生产环境 Linux 服务器使用)
# DATA_DIR=/opt/nercar-portal/data

# 时区
TZ=Asia/Shanghai
