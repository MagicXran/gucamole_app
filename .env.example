# Docker Compose 规范变量名
PORTAL_INSTANCE_ID=nercar-portal
MYSQL_ROOT_PASSWORD=your_strong_root_password
MYSQL_USER=guacamole_user
MYSQL_PASSWORD=your_strong_db_password
MYSQL_DATABASE=guacamole_db

# 开发态默认暴露到宿主机 33060；并行实例时为每套实例显式改掉它
# MYSQL_HOST_PORT=33060

# 可选: 生产环境直接挂载服务器目录
# MYSQL_DATA_SOURCE=/srv/nercar-portal/mysql
# GUAC_DRIVE_SOURCE=/srv/nercar-portal/drive

# Guacamole Encrypted JSON Auth 共享密钥
# 生成方法: python -c "import secrets; print(secrets.token_hex(16))"
# 必须是 32 位十六进制字符串（128-bit AES 密钥）
JSON_SECRET_KEY=your_32_char_hex_key_here

# 兼容旧变量名（历史环境可保留；新环境优先使用上面的规范名）
# GUAC_DB_ROOT_PASSWORD=your_strong_root_password
# GUAC_DB_PASSWORD=your_strong_db_password
# GUACAMOLE_JSON_SECRET_KEY=your_32_char_hex_key_here
