# Guacamole RemoteApp Portal — Windows 开发机 + Worker VM 模板
# 用法：
# 1. 复制本文件为 deploy/.env
# 2. 在 deploy 目录启动 docker compose up -d --build
# 3. 另开一个宿主机终端启动下面的 bridge
#
# 开发机网络假设：
# - 宿主机 VMnet8: 192.168.56.25
# - Worker VM: 192.168.56.6
# - Docker/nginx 只监听宿主机回环地址 127.0.0.1:18880
# - bridge 对 Worker VM 暴露 192.168.56.25:8880
#
# bridge 命令：
# python deploy\host_port_bridge.py --listen-host 192.168.56.25 --listen-port 8880 --target-host 127.0.0.1 --target-port 18880
#
# Worker registration_payload.json:
# portal_base_url=http://192.168.56.25:8880

PORTAL_INSTANCE_ID=nercar-portal-dev

MYSQL_ROOT_PASSWORD=xran
MYSQL_USER=guacamole_user
MYSQL_PASSWORD=xran
MYSQL_DATABASE=guacamole_db

JSON_SECRET_KEY=4c0b569e4c96df157eee1b65dd0e4d41

# Docker 实际监听地址：只给本机 bridge 访问
PORTAL_HOST=127.0.0.1
PORTAL_BIND_IP=127.0.0.1
PORTAL_PORT=18880

# 浏览器 / Worker VM 实际访问地址：经 bridge 暴露
PORTAL_PUBLIC_HOST=192.168.56.25
PORTAL_PUBLIC_PORT=8880

PORTAL_JWT_SECRET=f7a3d9e2c1b5084a6e3f1d8b2a5c7e09

# Windows 开发环境保持注释，MySQL 8 不要绑 NTFS 数据目录
# MYSQL_DATA_SOURCE=/srv/nercar-portal/mysql
# GUAC_DRIVE_SOURCE=/srv/nercar-portal/drive

TZ=Asia/Shanghai
